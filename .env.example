# Порт, на котором запустится сервер
PORT=4000

# Адрес вашего фронтенда после деплоя (для CORS). Для локальной разработки
# можно оставить как есть.
FRONTEND_URL=http://localhost:5173

# Строка подключения к Postgres — скопируйте из Supabase / Neon / Railway
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Секрет для подписи JWT-токенов — впишите любую длинную случайную строку
JWT_SECRET=change-me-to-a-random-long-string

# ===== Composio =====
# Личный API-ключ из личного кабинета composio.dev
COMPOSIO_API_KEY=your_composio_api_key

# ID Auth Config для Google Calendar, созданного в дашборде Composio
# (Composio → Auth Configs → New → Google Calendar → вписать свои
# client_id/client_secret из Google Cloud Console)
COMPOSIO_GOOGLE_AUTH_CONFIG_ID=your_auth_config_id
